# GSTV Domo API credentials — copy to .env and fill in the real values.

# --- Primary auth: Domo Developer Access Token ------------------------------
# Created in: Admin → Security → Access tokens on <instance>.domo.com
# Sent as: X-DOMO-Developer-Token header against https://<instance>.domo.com
DOMO_ACCESS_TOKEN=DDCIc6278ee87fb436fc1844ebb3d1e23e67bdbc1cb400582567
DOMO_INSTANCE=gstv

# --- Fallback auth: OAuth2 client_credentials (public API, api.domo.com) ----
# Created in: developer.domo.com → My Account → New Client
# DomoClient uses this only when DOMO_ACCESS_TOKEN is not set.
DOMO_CLIENT_ID=
DOMO_CLIENT_SECRET=
